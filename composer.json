{
    "name": "ahmadi/laravel-sepidar",
    "description": "Laravel package for integrating with Sepidar (سپیدار) accounting software API",
    "keywords": [
        "laravel",
        "sepidar",
        "سپیدار",
        "accounting",
        "api"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Ahmadi",
            "email": "your-email@example.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "ext-openssl": "*"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Ahmadi\\LaravelSepidar\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ahmadi\\LaravelSepidar\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ahmadi\\LaravelSepidar\\SepidarServiceProvider"
            ],
            "aliases": {
                "Sepidar": "Ahmadi\\LaravelSepidar\\Facades\\Sepidar"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    }
}
